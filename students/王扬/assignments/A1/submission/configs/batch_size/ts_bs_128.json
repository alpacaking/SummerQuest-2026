{
  "seed": 0,
  "out_dir": "artifacts/runs/batch_size/ts_bs_128",
  "train_tokens_path": "artifacts/datasets/tinystories_train.npy",
  "val_tokens_path": "artifacts/datasets/tinystories_valid.npy",
  "batch_size": 128,
  "max_steps": 2000,
  "eval_interval": 200,
  "eval_batches": 10,
  "save_interval": 1000,
  "grad_clip": 1.0,
  "model": {
    "vocab_size": 10000,
    "context_length": 256,
    "d_model": 512,
    "num_layers": 4,
    "num_heads": 16,
    "d_ff": 1344,
    "rope_theta": 10000.0,
    "use_rope": true,
    "use_rmsnorm": true,
    "prenorm": true,
    "ffn_type": "swiglu",
    "eps": 1e-05
  },
  "optimizer": {
    "learning_rate": 0.0005,
    "weight_decay": 0.1,
    "betas": [0.9, 0.999],
    "eps": 1e-08
  },
  "schedule": {
    "max_learning_rate": 0.0005,
    "min_learning_rate": 0.00005,
    "warmup_iters": 200,
    "cosine_cycle_iters": 2000
  }
}

